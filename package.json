{
  "name": "tree-bookmarks",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "postinstall": "npm run db:generate -w server",
    "dev": "concurrently \"npm run dev -w server\" \"npm run dev -w client\"",
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "build": "npm run build -w server && npm run build -w client",
    "db:generate": "npm run db:generate -w server",
    "db:push": "npm run db:push -w server",
    "db:seed": "npm run db:seed -w server",
    "db:init": "npm run db:push -w server && npm run db:seed -w server"
  },
  "overrides": {
    "csstype": "3.1.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
