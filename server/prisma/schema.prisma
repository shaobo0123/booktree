generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Bookmark {
  id        String     @id @default(cuid())
  parentId  String?    @map("parent_id")
  title     String
  type      String
  url       String?
  faviconUrl    String?    @map("favicon_url")
  faviconBase64 String?    @map("favicon_base64")
  faviconMime   String?    @map("favicon_mime")
  sortOrder Int        @default(0) @map("sort_order")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  parent    Bookmark?  @relation("BookmarkChildren", fields: [parentId], references: [id])
  children  Bookmark[] @relation("BookmarkChildren")

  @@index([parentId, sortOrder])
  @@map("bookmarks")
}
